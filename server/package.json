{
  "name": "alexa-photos-server",
  "version": "1.0.11",
  "description": "Sync iCloud shared album to Amazon Photos for Echo Show display",
  "type": "module",
  "scripts": {
    "dev": "cd .. && tsx watch server/src/index.ts",
    "build": "cd .. && tsc -p server/tsconfig.json",
    "start": "cd .. && node server/dist/index.js",
    "test": "cd .. && vitest --config server/vitest.config.ts",
    "test:run": "cd .. && vitest run --config server/vitest.config.ts",
    "lint": "cd .. && eslint --config server/eslint.config.js server/src/",
    "lint:fix": "cd .. && eslint --config server/eslint.config.js server/src/ --fix",
    "format": "cd .. && prettier --write \"server/src/**/*.ts\"",
    "format:check": "cd .. && prettier --check \"server/src/**/*.ts\"",
    "icloud:test": "cd .. && tsx server/src/icloud/test.ts",
    "amazon:verify": "cd .. && tsx server/src/amazon/verify-live.ts",
    "notifications:test": "cd .. && NODE_OPTIONS='--import tsx' node --env-file=.env server/src/lib/test-notifications.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.4.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.1.0",
    "tsx": "^4.6.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
}
